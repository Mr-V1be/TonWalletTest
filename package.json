{
  "name": "ton-wallet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start:all": "node ./ops/run-docker.mjs",
    "start:local": "node ./ops/run-local.mjs",
    "docker:up": "docker compose -f ./ops/compose.yml up --build -d",
    "docker:down": "docker compose -f ./ops/compose.yml down -v",
    "docker:logs": "docker compose -f ./ops/compose.yml logs -f",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-router": "^1.139.3",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.0.0",
    "buffer": "^6.0.3",
    "lucide-react": "^1.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
